# Environment Variables for FAERS SGLT2-DKA Analysis

# These variables can be set in your shell or .env file

# FAERS Data Directory
# Set this if your raw data is in a non-standard location
# FAERS_RAW_DIR=./data/raw

# Intermediate data directory
# FAERS_INTERIM_DIR=./data/interim

# Processed data directory
# FAERS_PROCESSED_DIR=./data/processed

# Output directory for results
# FAERS_OUTPUT_DIR=./outputs/paper_results

# Random seed for reproducibility (optional, defaults to 42)
# RANDOM_SEED=42

# Number of workers for parallel processing (optional)
# N_WORKERS=4

# API key for FDA data download (if using authenticated access)
# FDA_API_KEY=your_api_key_here

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
